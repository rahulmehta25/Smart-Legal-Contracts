# Smart Legal Contracts Frontend - Environment Configuration
# Copy this file to .env.local for local development

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Backend API URL
# For production: Your deployed FastAPI backend URL
# For development: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (optional, auto-derived from API URL if not set)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# API request timeout in milliseconds (default: 30000)
NEXT_PUBLIC_API_TIMEOUT=30000

# Maximum file upload size in bytes (default: 50MB)
NEXT_PUBLIC_MAX_FILE_SIZE=52428800

# =============================================================================
# DEBUG
# =============================================================================

# Enable debug mode
NEXT_PUBLIC_DEBUG=false
